# LLM provider — use either ANTHROPIC_API_KEY (direct) or OPENROUTER_API_KEY (OpenRouter proxy)
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
# Model name. Direct Anthropic: claude-sonnet-4-6. OpenRouter: anthropic/claude-sonnet-4-6
AGENT_MODEL=claude-sonnet-4-6

# GitHub — Personal Access Token or GitHub App installation token
# Required scopes: repo (read/write contents, pull requests, issues)
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
# Base branch for pull requests
GITHUB_BASE_BRANCH=main

# OpenMemory app — the Laravel instance this agent reads memories from and writes to
OMA_API_URL=http://localhost:8000
OMA_API_KEY=
# Must match a user_id in the OpenMemory database
OMA_USER_ID=

# Path to the repository root. Defaults to the parent of the agent/ directory.
# All file operations are confined to this path.
REPO_PATH=..

# Connectors — enable at least one by filling in its credentials

# Discord
DISCORD_BOT_TOKEN=
# The specific server (guild) the bot should respond in
DISCORD_GUILD_ID=
# The specific channel the bot should read and write messages in
DISCORD_CHANNEL_ID=
# Comma-separated Discord user IDs allowed to issue commands (your Discord user ID)
DISCORD_ALLOWED_USER_IDS=
