# Quick local dev without Docker (SQLite + mock memory).
# Usage:
#   cp .env.sqlite .env
#   php artisan migrate
#   php artisan serve

APP_NAME=OpenMemoryAgent
APP_ENV=local
APP_KEY=base64:l7Daapk5Xrryok2y5SvA6RBj0wtei8pZ6ItOAMYzF3k=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12
LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync

# ─── LLM Provider ────────────────────────────────────────────────
LLM_PROVIDER=claude
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
GEMINI_API_KEY=
OPENAI_API_KEY=

# ─── ICP Memory Layer ─────────────────────────────────────────────
# ICP_MOCK_MODE=true  → file cache (no adapter needed)
# ICP_MOCK_MODE=false → adapter must be running at ICP_CANISTER_ENDPOINT
ICP_MOCK_MODE=true
ICP_CANISTER_ENDPOINT=http://localhost:3100
ICP_CANISTER_ID=
ICP_BROWSER_HOST=http://localhost:4943

VITE_APP_NAME="${APP_NAME}"
