APP_NAME=OpenMemoryAgent
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─── Database ─────────────────────────────────────────────────────
# Docker (PostgreSQL):
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=open_memory
DB_USERNAME=oma_user
DB_PASSWORD=secret

# Local dev without Docker (SQLite):
# DB_CONNECTION=sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync

FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

# ─── LLM Provider ────────────────────────────────────────────────
# Options: claude | gemini | openai
LLM_PROVIDER=claude

CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── ICP Memory Layer ─────────────────────────────────────────────
# ICP_MOCK_MODE=true  → stores memories in file cache (no canister needed)
# ICP_MOCK_MODE=false → calls the Node adapter at ICP_CANISTER_ENDPOINT
#
# To run with a real canister:
#   1. cd icp && dfx start --background && dfx deploy
#   2. cd icp/adapter && npm install && ICP_MOCK=false node server.js
#   3. Set ICP_MOCK_MODE=false and ICP_CANISTER_ENDPOINT=http://localhost:3100
ICP_MOCK_MODE=true
ICP_CANISTER_ENDPOINT=http://localhost:3100
ICP_CANISTER_ID=

VITE_APP_NAME="${APP_NAME}"
